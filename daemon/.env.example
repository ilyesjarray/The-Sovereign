# =====================================================
# Sovereign Daemon — Environment Configuration
# Copy this to .env and fill in your values
# =====================================================

# Supabase Configuration (REQUIRED)
# Get service_role key from: Supabase Dashboard → Settings → API → service_role
SUPABASE_URL=https://ybrtpasetldpxanrhsle.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlicnRwYXNldGxkcHhhbnJoc2xlIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MDMxODIyOSwiZXhwIjoyMDg1ODk0MjI5fQ.cU0dJmsKn1PSkfJMV4qOQR6CRxlvmVmstP5R2-57LVc

# ADB Configuration (OPTIONAL)
# Path to adb binary. Defaults to 'adb' (assumes it's in PATH)
ADB_PATH=adb

# Timing Configuration (OPTIONAL)
# Seconds between polling cycles (default: 5)
POLL_INTERVAL=5

# Seconds to wait for USSD response dialog to appear (default: 7)
USSD_WAIT_TIME=7

# Seconds between USSD executions to avoid carrier anti-spam (default: 5)
COOLDOWN_TIME=5

# USSD Configuration (OPTIONAL)
# USSD code template. {pin} is replaced with the actual PIN code.
USSD_TEMPLATE=*101*{pin}#
